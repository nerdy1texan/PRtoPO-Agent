{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PR Line Items",
  "description": "Purchase Requisition line items — from PR form. Used by checks 4 (description match), 5 (quantity/UOM), 6 (price/amount), 7 (currency), 9 (category), 12 (delivery/lead time).",
  "type": "object",
  "required": ["pr_number", "line_items"],
  "properties": {
    "pr_number": { "type": "string", "description": "PR identifier; links to PR Header." },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["line_number", "quantity", "unit_of_measure", "unit_price_usd", "extended_amount_usd"],
        "properties": {
          "line_number": { "type": "integer", "description": "Line sequence (10, 20, …)." },
          "item_short_description": { "type": "string", "description": "Short item description. Check 4 (vs quote line)." },
          "item_long_description": { "type": "string", "description": "Full spec; used for semantic match in Check 4." },
          "material_number": { "type": "string", "description": "Internal/material number." },
          "commodity_code": { "type": "string", "description": "Commodity code (e.g. 43211500). Check 9." },
          "category_l1": { "type": "string" },
          "category_l2": { "type": "string" },
          "category_l3": { "type": "string" },
          "category_l4": { "type": "string", "description": "Category for Check 9, 10, 12." },
          "quantity": { "type": "number", "description": "Quantity. Check 5 (match quote)." },
          "unit_of_measure": { "type": "string", "description": "UOM (e.g. Each, Hours). Check 5 (normalized)." },
          "unit_price_usd": { "type": "number", "description": "Unit price. Check 6 (vs quote)." },
          "extended_amount_usd": { "type": "number", "description": "Line total. Check 6 (vs quote total)." },
          "suggested_supplier_id": { "type": "string", "description": "Supplier ID (e.g. V-10042). Check 3." },
          "suggested_supplier_name": { "type": "string", "description": "Supplier name. Check 3 (match document & master)." },
          "need_by_date_line": { "type": "string", "format": "date", "description": "Line-level need-by. Check 12." },
          "delivery_address": { "type": "string", "description": "Delivery address for this line." },
          "asset_tag_required": { "type": "boolean", "description": "Asset tag required (e.g. for IT hardware)." },
          "notes": { "type": "string", "description": "Line-level notes." }
        }
      }
    }
  },
  "example": {
    "pr_number": "PR-2026-007842",
    "line_items": [
      {
        "line_number": 10,
        "item_short_description": "Lenovo ThinkPad P16 Gen 2 — i7/32GB/1TB/RTX A1000",
        "item_long_description": "Lenovo ThinkPad P16 Gen 2 Mobile Workstation, Intel Core i7-13850HX (24 cores), 32GB DDR5-5600 RAM, 1TB PCIe Gen4 NVMe SSD, NVIDIA RTX A1000 6GB, 16\" WQXGA IPS 400nit display, Windows 11 Pro, 3-Year Premier Onsite Warranty. Lenovo P/N: 21FA000GUS. CDW P/N: 7458923.",
        "material_number": "MAT-IT-00472",
        "commodity_code": "43211500",
        "category_l1": "IT",
        "category_l2": "IT Hardware",
        "category_l3": "End User Computing",
        "category_l4": "Laptops & Workstations",
        "quantity": 25,
        "unit_of_measure": "Each",
        "unit_price_usd": 2650.00,
        "extended_amount_usd": 66250.00,
        "suggested_supplier_id": "V-10042",
        "suggested_supplier_name": "CDW Corporation",
        "need_by_date_line": "2026-02-28",
        "delivery_address": "200 Seaport Blvd, 14th Floor, Boston, MA 02210",
        "asset_tag_required": true,
        "notes": "Config per Engineering standard build. Image: ENG-STD-2028-Q1"
      },
      {
        "line_number": 20,
        "item_short_description": "Lenovo ThinkPad Thunderbolt 4 Dock — 40B00135US",
        "item_long_description": "Lenovo ThinkPad Universal Thunderbolt 4 Dock. 4x USB-A 3.2, 1x USB-C 3.2, 2x Thunderbolt 4, 2x HDMI 2.1, 1x DisplayPort 1.4a, 1x Ethernet RJ45 2.5GbE, 1x 3.5mm combo audio. 135W power delivery. Lenovo P/N: 40B00135US. CDW P/N: 7129456",
        "material_number": "MAT-IT-00519",
        "commodity_code": "43211500",
        "category_l1": "IT",
        "category_l2": "IT Hardware",
        "category_l3": "End User Computing",
        "category_l4": "Docking Stations & Peripherals",
        "quantity": 25,
        "unit_of_measure": "Each",
        "unit_price_usd": 200.00,
        "extended_amount_usd": 5000.00,
        "suggested_supplier_id": "V-10042",
        "suggested_supplier_name": "CDW Corporation",
        "need_by_date_line": "2026-02-28",
        "delivery_address": "200 Seaport Blvd, 14th Floor, Boston, MA 02210",
        "asset_tag_required": false,
        "notes": "Bundle with laptop order for volume discount per CDW quote."
      }
    ]
  }
}
