{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PR Header",
  "description": "Purchase Requisition header — from PR form/upload. Used by compliance checks 1–12 (attachment count, PR date, supplier, total, currency, payment terms, category, buying channel, delivery/lead time).",
  "type": "object",
  "required": ["pr_number", "pr_status", "pr_created_date", "total_estimated_value", "currency"],
  "properties": {
    "pr_number": { "type": "string", "description": "Unique PR identifier (e.g. PR-2026-007842). Check 2, 3, 10." },
    "pr_status": { "type": "string", "enum": ["Draft", "Submitted", "In Review", "Approved", "Rejected"], "description": "Current PR status." },
    "pr_created_date": { "type": "string", "format": "date", "description": "PR creation date. Check 2 (quote date before PR date), Check 11 (ATF – document dates), Check 12 (lead time)." },
    "pr_creator": { "type": "string", "description": "User who created the PR." },
    "requestor_name": { "type": "string", "description": "Requestor full name. Check 3 (supplier context)." },
    "requestor_email": { "type": "string", "format": "email", "description": "Requestor email." },
    "department": { "type": "string", "description": "Requesting department." },
    "cost_center": { "type": "string", "description": "Cost center code (e.g. CC-4120-ENG)." },
    "cost_center_name": { "type": "string", "description": "Cost center display name." },
    "company_code": { "type": "string", "description": "Company/legal entity code (e.g. 1000). Check 2 (document applies to same legal entity)." },
    "company_name": { "type": "string", "description": "Company/legal entity name." },
    "plant_ship_to": { "type": "string", "description": "Plant or ship-to location ID." },
    "ship_to_address": { "type": "string", "description": "Full ship-to address." },
    "currency": { "type": "string", "description": "Currency code (e.g. USD). Check 7." },
    "total_estimated_value": { "type": "number", "description": "Total PR value. Check 6 (vs quote total)." },
    "justification_text": { "type": "string", "description": "Business justification." },
    "urgency_flag": { "type": "string", "enum": ["Low", "Normal", "High", "Critical"], "description": "Urgency." },
    "framework_order": { "type": "boolean", "description": "Whether this is a framework/contract order." },
    "region": { "type": "string", "description": "Region (e.g. US-East)." },
    "payment_terms_pr": { "type": "string", "description": "Payment terms on PR (e.g. Net 30). Check 8 (vs contract/policy)." },
    "need_by_date": { "type": "string", "format": "date", "description": "Required delivery date. Check 12 (lead time)." },
    "approval_flow": { "type": "string", "description": "Approval path (L1 -> L2 -> …)." },
    "cnp_required": { "type": "boolean", "description": "Central/Corporate NP approval required." },
    "cnp_approver": { "type": "string", "description": "CNP approver name." },
    "pr_comments": { "type": "string", "description": "Comments on the PR." },
    "number_of_attachments": { "type": "integer", "minimum": 0, "description": "Count of attachments. Check 1 (required documents for value tier)." },
    "buying_channel": { "type": "string", "enum": ["Catalog", "Contract", "Spot", "Other"], "description": "Channel used. Check 10." },
    "contract_reference": { "type": "string", "description": "Contract/MSA reference if channel is Contract (e.g. CNT-2024-0892, MSA-CDW-2024-0156). Check 8, 10." },
    "category_l1": { "type": "string", "description": "Category L1 (e.g. IT). Check 9." },
    "category_l2": { "type": "string", "description": "Category L2 (e.g. IT Hardware)." },
    "category_l3": { "type": "string", "description": "Category L3 (e.g. End User Computing)." },
    "category_l4": { "type": "string", "description": "Category L4 / category card (e.g. Marketing Services). Check 9, 12 (lead time by category)." }
  },
  "example": {
    "pr_number": "PR-2026-007842",
    "pr_status": "Submitted",
    "pr_created_date": "2026-01-15",
    "pr_creator": "Martinez, Sofia",
    "requestor_name": "Chen, David",
    "requestor_email": "david.chen@meridiantech.com",
    "department": "Engineering — Platform Infrastructure",
    "cost_center": "CC-4120-ENG",
    "company_code": "1000",
    "company_name": "Meridian Technologies Inc.",
    "plant_ship_to": "Plant 1000-Boston",
    "ship_to_address": "200 Seaport Blvd, 14th Floor, Boston, MA 02210",
    "currency": "USD",
    "total_estimated_value": 571250.00,
    "justification_text": "Annual laptop refresh for Platform Engineering team (25 engineers)...",
    "urgency_flag": "Normal",
    "framework_order": false,
    "region": "US-East",
    "payment_terms_pr": "Net 30",
    "need_by_date": "2026-02-20",
    "approval_flow": "L1: Martinez, Sofia (Auto) -> L2: Chen, David ($0-25K) -> L3: Patel, Raj ($25K-75K) -> L4: CNP - Williams, Karen (>$50K IT Hardware)",
    "cnp_required": true,
    "cnp_approver": "Williams, Karen (VP Procurement)",
    "number_of_attachments": 4,
    "buying_channel": "Contract",
    "contract_reference": "MSA-CDW-2024-0156",
    "category_l1": "IT",
    "category_l2": "IT Hardware",
    "category_l3": "End User Computing",
    "category_l4": "Laptops & Workstations"
  }
}
