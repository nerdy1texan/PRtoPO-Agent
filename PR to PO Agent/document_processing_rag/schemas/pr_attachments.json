{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PR Attachments",
  "description": "Metadata for documents attached to a PR. Used by Check 1 (existence & classification), Check 11 (ATF: invoice check, document dates). Documents are classified and parsed into Quote/MSA/SOW/Invoice etc.",
  "type": "object",
  "required": ["pr_number", "attachments"],
  "properties": {
    "pr_number": { "type": "string", "description": "PR identifier." },
    "attachment_count": { "type": "integer", "minimum": 0, "description": "Total count. Check 1 (required docs for value tier)." },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attachment_number", "file_name", "file_type", "document_classification"],
        "properties": {
          "attachment_number": { "type": "integer", "description": "Sequence (1, 2, 3, …)." },
          "file_name": { "type": "string", "description": "Original file name (e.g. CDW_Quote_Q25-0847_Meridian_ThinkPad_P16.pdf)." },
          "file_type": { "type": "string", "enum": ["PDF", "Excel", "Word", "Other"], "description": "File format." },
          "document_classification": {
            "type": "string",
            "enum": [
              "Supplier Quotation",
              "Master Service Agreement / Contract Services",
              "Competitive Quote Comparison",
              "Technical Evaluation / Business Case",
              "SOW",
              "Invoice",
              "Other"
            ],
            "description": "Agent-classified type. Check 1 (Quote/SOW/Contract present). Check 11 (no invoice for new PR)."
          },
          "classification_confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Confidence of classification (e.g. 0.94)." },
          "uploaded_by": { "type": "string", "description": "User who uploaded." },
          "upload_date": { "type": "string", "format": "date", "description": "Upload date. Check 11 (backdated detection)." },
          "file_size_kb": { "type": "number", "description": "File size in KB." },
          "description": { "type": "string", "description": "Human or system description of document content." },
          "document_date": { "type": "string", "format": "date", "description": "Date on document (quote date, contract date). Check 2, 11 (before or on PR date)." },
          "s3_key_or_path": { "type": "string", "description": "Storage path for pipeline (optional)." }
        }
      }
    }
  },
  "example": {
    "pr_number": "PR-2026-007842",
    "attachment_count": 4,
    "attachments": [
      {
        "attachment_number": 1,
        "file_name": "CDW_Quote_Q25-0847_Meridian_ThinkPad_P16.pdf",
        "file_type": "PDF",
        "document_classification": "Supplier Quotation",
        "classification_confidence": 0.94,
        "uploaded_by": "Martinez, Sofia",
        "upload_date": "2026-01-14",
        "file_size_kb": 342,
        "description": "CDW formal quotation for 25x ThinkPad P16 Gen 2 + 25x TB4 docks. Valid through 03/15/2026."
      },
      {
        "attachment_number": 2,
        "file_name": "MSA-CDW-2024-0156_Executed.pdf",
        "file_type": "PDF",
        "document_classification": "Master Service Agreement / Contract Services",
        "classification_confidence": 0.98,
        "uploaded_by": "Procurement Shared Services",
        "upload_date": "2024-03-01",
        "file_size_kb": 1280,
        "description": "Executed MSA with CDW Corporation. Effective 01/01/2024 through 12/31/2026. Covers IT hardware, software, and related services."
      },
      {
        "attachment_number": 3,
        "file_name": "Competitive_Quotes_Summary_IT-HW-Jan2026.xlsx",
        "file_type": "Excel",
        "document_classification": "Competitive Quote Comparison",
        "classification_confidence": 0.89,
        "uploaded_by": "Martinez, Sofia",
        "upload_date": "2026-01-13",
        "file_size_kb": 89,
        "description": "3-bid comparison: CDW vs SHI International vs Insight Direct. CDW lowest total cost of ownership."
      },
      {
        "attachment_number": 4,
        "file_name": "ThinkPad_P16_Gen2_Tech_Eval_Engineering.pdf",
        "file_type": "PDF",
        "document_classification": "Technical Evaluation / Business Case",
        "classification_confidence": 0.91,
        "uploaded_by": "Chen, David",
        "upload_date": "2026-01-10",
        "file_size_kb": 567,
        "description": "Engineering team technical evaluation comparing ThinkPad P16 Gen 2 vs Dell Precision 7680 vs HP ZBook Fury 16 G10."
      }
    ]
  }
}
