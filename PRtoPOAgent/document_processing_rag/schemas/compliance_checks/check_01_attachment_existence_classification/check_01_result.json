{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Check 1: Attachment Existence & Document Classification — Result",
  "description": "Output of Check 1 (gatekeeper). Confirms required supporting documentation is attached and correctly classified per policy. Does NOT extract detailed fields — only document types. Ref: PR_Compliance_Check1_Check2_Fields.md §1.",
  "type": "object",
  "required": ["check_id", "check_name", "check_1_status", "attachments_found", "classified_documents", "policy_requirements_met"],
  "properties": {
    "check_id": { "type": "string", "const": "check_01", "description": "Stable check identifier." },
    "check_name": { "type": "string", "const": "Attachment Existence & Classification", "description": "Display name." },
    "check_1_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "NEEDS_REVIEW"],
      "description": "Overall result. PASS = policy requirements met; FAIL = missing required docs; NEEDS_REVIEW = low confidence or edge case."
    },
    "attachments_found": { "type": "integer", "minimum": 0, "description": "Count of attachments on PR." },
    "classified_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "document_type", "confidence"],
        "properties": {
          "filename": { "type": "string", "description": "Attachment file name." },
          "document_type": {
            "type": "string",
            "enum": ["PR Form", "Quotation", "Contract", "SOW", "Service Agreement", "Invoice", "BidSummary", "Justification", "Spec", "Other"],
            "description": "LLM classification. PR Form = PR header/line items/attachments data (Excel); Quotation|Contract|SOW|SA count as valid support; Invoice triggers ATF (Check 11)."
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Classification confidence. < 0.8 triggers NEEDS_REVIEW." },
          "reason": { "type": "string", "description": "Brief explanation for audit trail." }
        }
      },
      "description": "Per-attachment classification from LLM."
    },
    "valid_support_docs_found": { "type": "integer", "minimum": 0, "description": "Count of docs classified as Quote/Contract/SOW/SA." },
    "policy_requirements_met": { "type": "boolean", "description": "True if documentation meets threshold policy for this PR value/category." },
    "missing_requirements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Human-readable list of what's missing (e.g. 'Requires 3 quotes, only 1 found')."
    },
    "invoice_detected": { "type": "boolean", "description": "True if any attachment classified as Invoice — red flag for After-the-Fact (Check 11)." },
    "sub_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "passed": { "type": "boolean" }
        }
      },
      "description": "For UI: At least one attachment; Agent classified as Quote/SOW/Contract; Required docs for value tier present."
    },
    "field_level_assessment": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field_name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "review"] },
          "confidence": { "type": "number" },
          "detail": { "type": "string" }
        }
      },
      "description": "For UI: e.g. Attachment Count, Quote Document Type."
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "extracted_value": { "type": "string" },
          "pr_value": { "type": "string" },
          "match": { "type": "string", "enum": ["Match", "Partial", "Mismatch"] }
        }
      }
    },
    "policy_reference": { "type": "string", "description": "e.g. Procurement Policy v3.2, Section 3.1" }
  },
  "example": {
    "check_id": "check_01",
    "check_name": "Attachment Existence & Classification",
    "check_1_status": "PASS",
    "attachments_found": 2,
    "classified_documents": [
      {
        "filename": "Acme_Quote_Jan2026.pdf",
        "document_type": "Quotation",
        "confidence": 0.94,
        "reason": "Keywords: Quote, Valid Until; line items with prices; supplier letterhead."
      },
      {
        "filename": "SOW_Marketing_Services.pdf",
        "document_type": "SOW",
        "confidence": 0.89,
        "reason": "Keywords: Statement of Work, Scope; deliverables and timeline present."
      }
    ],
    "valid_support_docs_found": 2,
    "policy_requirements_met": true,
    "missing_requirements": [],
    "invoice_detected": false,
    "sub_checks": [
      { "name": "At least one attachment exists on PR", "passed": true },
      { "name": "Agent classified attachment as Quote/SOW/Contract", "passed": true },
      { "name": "Required documents for value tier present", "passed": true }
    ],
    "field_level_assessment": [
      {
        "field_name": "Attachment Count",
        "status": "pass",
        "confidence": 1.0,
        "detail": "2 documents attached (meets minimum requirement)"
      },
      {
        "field_name": "Quote Document Type",
        "status": "pass",
        "confidence": 0.94,
        "detail": "Acme_Quote_Jan2026.pdf classified as Quote"
      }
    ],
    "evidence": [
      { "field": "Attachments Found", "extracted_value": "2 documents", "pr_value": "Required: ≥1", "match": "Match" },
      { "field": "Document Types", "extracted_value": "Quote (94%), SOW (89%)", "pr_value": "Expected: Quote or Contract", "match": "Match" }
    ],
    "policy_reference": "Procurement Policy v3.2, Section 3.1"
  }
}
