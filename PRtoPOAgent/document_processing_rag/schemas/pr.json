      "justification_text": "Annual laptop refresh for Platform Engineering team (25 engineers)...",
      "urgency_flag": "Normal",
      "framework_order": false,
      "region": "US-East",
      "payment_terms_pr": "Net 30",
      "need_by_date": "2026-02-20",
      "approval_flow": "L1: Martinez, Sofia (Auto) -> L2: Chen, David ($0-25K) -> L3: Patel, Raj ($25K-75K) -> L4: CNP - Williams, Karen (>$50K IT Hardware)",
      "cnp_required": true,
      "cnp_approver": "Williams, Karen (VP Procurement)",
      "number_of_attachments": 4,
      "buying_channel": "Contract",
      "contract_reference": "MSA-CDW-2024-0156",
      "category_l1": "IT",
      "category_l2": "IT Hardware",
      "category_l3": "End User Computing",
      "category_l4": "Laptops & Workstations"
    },
    "attachments": {
      "attachment_count": 4,
      "attachments": [
        { "attachment_number": 1, "file_name": "CDW_Quote_Q25-0847_Meridian_ThinkPad_P16.pdf", "file_type": "PDF", "document_classification": "Supplier Quotation", "classification_confidence": 0.94, "uploaded_by": "Martinez, Sofia", "upload_date": "2026-01-14", "file_size_kb": 342, "description": "CDW formal quotation for 25x ThinkPad P16 Gen 2 + 25x TB4 docks. Valid through 03/15/2026." },
        { "attachment_number": 2, "file_name": "MSA-CDW-2024-0156_Executed.pdf", "file_type": "PDF", "document_classification": "Master Service Agreement / Contract Services", "classification_confidence": 0.98, "uploaded_by": "Procurement Shared Services", "upload_date": "2024-03-01", "file_size_kb": 1280, "description": "Executed MSA with CDW Corporation. Effective 01/01/2024 through 12/31/2026." },
        { "attachment_number": 3, "file_name": "Competitive_Quotes_Summary_IT-HW-Jan2026.xlsx", "file_type": "Excel", "document_classification": "Competitive Quote Comparison", "classification_confidence": 0.89 },
        { "attachment_number": 4, "file_name": "ThinkPad_P16_Gen2_Tech_Eval_Engineering.pdf", "file_type": "PDF", "document_classification": "Technical Evaluation / Business Case", "classification_confidence": 0.91 }
