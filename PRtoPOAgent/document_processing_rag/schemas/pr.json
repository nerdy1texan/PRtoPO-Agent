      { "line_number": 20, "item_short_description": "Lenovo ThinkPad Thunderbolt 4 Dock — 40B00135US", "item_long_description": "Lenovo ThinkPad Universal Thunderbolt 4 Dock. 4x USB-A 3.2, 2x Thunderbolt 4, 2x HDMI 2.1, 1x DP 1.4a, 1x RJ45 2.5GbE, 135W PD.", "material_number": "MAT-IT-00519", "commodity_code": "43211500", "category_l1": "IT", "category_l2": "IT Hardware", "category_l3": "End User Computing", "category_l4": "Docking Stations & Peripherals", "quantity": 25, "unit_of_measure": "Each", "unit_price_usd": 200, "extended_amount_usd": 5000, "suggested_supplier_id": "V-10042", "suggested_supplier_name": "CDW Corporation", "need_by_date_line": "2026-02-28", "delivery_address": "200 Seaport Blvd, 14th Floor, Boston, MA 02210", "asset_tag_required": false, "notes": "Bundle with laptop order." }
    ]
  }
}
