{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PR (Purchase Requisition)",
  "description": "Single PR template: header + attachments + line items. Used by compliance checks 1–12 and system prompts. Replaces pr_header, pr_line_items, pr_attachments.",
  "type": "object",
  "required": ["header", "attachments", "line_items"],
  "properties": {
    "header": {
      "type": "object",
      "required": ["pr_number", "pr_status", "pr_created_date", "total_estimated_value", "currency"],
      "properties": {
        "pr_number": { "type": "string", "description": "Unique PR identifier (e.g. PR-2026-007842)." },
        "pr_status": { "type": "string", "enum": ["Draft", "Submitted", "In Review", "Approved", "Rejected"], "description": "Current PR status." },
        "pr_created_date": { "type": "string", "format": "date", "description": "PR creation date. Check 2 (dates), Check 11 (ATF), Check 12 (lead time)." },
        "pr_creator": { "type": "string", "description": "User who created the PR." },
        "requestor_name": { "type": "string", "description": "Requestor full name." },
        "requestor_email": { "type": "string", "format": "email", "description": "Requestor email." },
        "department": { "type": "string", "description": "Requesting department." },
        "cost_center": { "type": "string", "description": "Cost center code (e.g. CC-4120-ENG)." },
        "cost_center_name": { "type": "string", "description": "Cost center display name." },
        "company_code": { "type": "string", "description": "Company/legal entity code (e.g. 1000)." },
        "company_name": { "type": "string", "description": "Company/legal entity name." },
        "plant_ship_to": { "type": "string", "description": "Plant or ship-to location ID." },
        "ship_to_address": { "type": "string", "description": "Full ship-to address." },
        "currency": { "type": "string", "description": "Currency code (e.g. USD). Check 7." },
        "total_estimated_value": { "type": "number", "description": "Total PR value. Check 6." },
        "justification_text": { "type": "string", "description": "Business justification." },
        "urgency_flag": { "type": "string", "enum": ["Low", "Normal", "High", "Critical"], "description": "Urgency." },
        "framework_order": { "type": "boolean", "description": "Whether this is a framework/contract order." },
        "region": { "type": "string", "description": "Region (e.g. US-East)." },
        "payment_terms_pr": { "type": "string", "description": "Payment terms on PR (e.g. Net 30). Check 8." },
        "need_by_date": { "type": "string", "format": "date", "description": "Required delivery date. Check 12." },
        "approval_flow": { "type": "string", "description": "Approval path (L1 -> L2 -> …)." },
        "cnp_required": { "type": "boolean", "description": "Central/Corporate NP approval required." },
        "cnp_approver": { "type": "string", "description": "CNP approver name." },
        "pr_comments": { "type": "string", "description": "Comments on the PR." },
        "number_of_attachments": { "type": "integer", "minimum": 0, "description": "Count of attachments. Check 1." },
        "buying_channel": { "type": "string", "enum": ["Catalog", "Contract", "Spot", "Other"], "description": "Channel used. Check 10." },
        "contract_reference": { "type": "string", "description": "Contract/MSA reference if channel is Contract. Check 8, 10." },
        "category_l1": { "type": "string", "description": "Category L1 (e.g. IT). Check 9." },
        "category_l2": { "type": "string", "description": "Category L2 (e.g. IT Hardware)." },
        "category_l3": { "type": "string", "description": "Category L3 (e.g. End User Computing)." },
        "category_l4": { "type": "string", "description": "Category L4 / category card. Check 9, 12." }
      }
    },
    "attachments": {
      "type": "object",
      "required": ["attachment_count", "attachments"],
      "properties": {
        "attachment_count": { "type": "integer", "minimum": 0, "description": "Total count. Check 1." },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["attachment_number", "file_name", "file_type", "document_classification"],
            "properties": {
              "attachment_number": { "type": "integer", "description": "Sequence (1, 2, 3, …)." },
              "file_name": { "type": "string", "description": "Original file name." },
              "file_type": { "type": "string", "enum": ["PDF", "Excel", "Word", "Other"], "description": "File format." },
              "document_classification": { "type": "string", "enum": ["Supplier Quotation", "Master Service Agreement / Contract Services", "Competitive Quote Comparison", "Technical Evaluation / Business Case", "SOW", "Invoice", "Other"], "description": "Agent-classified type. Check 1, 11." },
              "classification_confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Confidence of classification." },
              "uploaded_by": { "type": "string", "description": "User who uploaded." },
              "upload_date": { "type": "string", "format": "date", "description": "Upload date. Check 11." },
              "file_size_kb": { "type": "number", "description": "File size in KB." },
              "description": { "type": "string", "description": "Human or system description of document content." },
              "document_date": { "type": "string", "format": "date", "description": "Date on document. Check 2, 11." },
              "s3_key_or_path": { "type": "string", "description": "Storage path for pipeline (optional)." }
            }
          }
        }
      }
    },
    "line_items": {
      "type": "array",
      "description": "PR line items. Checks 4, 5, 6, 9, 12.",
      "items": {
        "type": "object",
        "required": ["line_number", "quantity", "unit_of_measure", "unit_price_usd", "extended_amount_usd"],
        "properties": {
          "line_number": { "type": "integer", "description": "Line sequence (10, 20, …)." },
          "item_short_description": { "type": "string", "description": "Short item description. Check 4." },
          "item_long_description": { "type": "string", "description": "Full spec; semantic match Check 4." },
          "material_number": { "type": "string", "description": "Internal/material number." },
          "commodity_code": { "type": "string", "description": "Commodity code. Check 9." },
          "category_l1": { "type": "string" },
          "category_l2": { "type": "string" },
          "category_l3": { "type": "string" },
          "category_l4": { "type": "string", "description": "Category for Check 9, 10, 12." },
          "quantity": { "type": "number", "description": "Quantity. Check 5." },
          "unit_of_measure": { "type": "string", "description": "UOM (e.g. Each, Hours). Check 5." },
          "unit_price_usd": { "type": "number", "description": "Unit price. Check 6." },
          "extended_amount_usd": { "type": "number", "description": "Line total. Check 6." },
          "suggested_supplier_id": { "type": "string", "description": "Supplier ID. Check 3." },
          "suggested_supplier_name": { "type": "string", "description": "Supplier name. Check 3." },
          "need_by_date_line": { "type": "string", "format": "date", "description": "Line-level need-by. Check 12." },
          "delivery_address": { "type": "string", "description": "Delivery address for this line." },
          "asset_tag_required": { "type": "boolean", "description": "Asset tag required (e.g. for IT hardware)." },
          "notes": { "type": "string", "description": "Line-level notes." }
        }
      }
    }
  },
  "example": {
    "header": {
      "pr_number": "PR-2026-007842",
      "pr_status": "Submitted",
      "pr_created_date": "2026-01-15",
      "pr_creator": "Martinez, Sofia",
