# =============================================================================
# PR to PO Agent — Environment configuration
# Copy to .env and set values. Section 0 validates required vars per mode.
# =============================================================================

# --- Mode: aws | local ---
#   aws  = Bedrock (LLM) + OpenSearch (vector) + Titan (embeddings)
#   local = Groq or Gemini (LLM) + Qdrant Cloud (vector) + sentence-transformers (embeddings)
# If unset, mode is auto-detected from which block of vars is present.
ENV_MODE=local

# ============ AWS (required when ENV_MODE=aws) ============
# AWS_REGION=us-east-1
# AWS_PROFILE=your-profile
# BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v2:0
# OPENSEARCH_ENDPOINT=https://your-domain-xxxxx.us-east-1.es.amazonaws.com
# OPENSEARCH_INDEX_NAME=pr2po-rag
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=your-password

# ============ Local (required when ENV_MODE=local) ============
# Set at least one LLM: GEMINI_API_KEY and/or GROQ_API_KEY. If both set, Gemini is used.
# QDRANT_URL and QDRANT_API_KEY are always required for local (vector store).

# Option A — Gemini (Google AI). Get key: https://ai.google.dev/gemini-api/docs/api-key
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash

# Option B — Groq
# GROQ_API_KEY=gsk_your_groq_api_key_here
# LOCAL_LLM_MODEL=llama-3.1-8b-instant

# Vector store (required for local)
# QDRANT_URL=https://your-cluster-id.us-east-1-1.aws.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_api_key
# QDRANT_COLLECTION_NAME=pr2po

# ============ Optional (both modes) ============
# DATABASE_URL=sqlite:///pr_validation.db
# LOCAL_DB_PATH=sqlite:///pr_validation.db
