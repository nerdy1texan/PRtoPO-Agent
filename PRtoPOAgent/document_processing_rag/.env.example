# =============================================================================
# PR to PO Agent — Environment configuration
# Copy to .env and set values. Section 0 validates required vars per mode.
# =============================================================================

# --- Mode: aws | local ---
# ENV_MODE is a convenience preset ONLY. You can mix-and-match providers with:
#   - LLM_PROVIDER: bedrock | gemini | groq
#   - EMBEDDINGS_PROVIDER: titan | sentence_transformers
#   - VECTOR_STORE_PROVIDER: pgvector | qdrant | opensearch | none
#
# Presets:
#   aws   (recommended cloud default): Bedrock LLM + Titan embeddings + PGVector
#   local (recommended local default): Groq/Gemini LLM + sentence-transformers + Qdrant
#
# If unset, the notebook auto-detects based on which variables are present.
ENV_MODE=local

# --- Provider overrides (optional; enables combos) ---
# LLM_PROVIDER=gemini
# EMBEDDINGS_PROVIDER=titan
# VECTOR_STORE_PROVIDER=pgvector

# ============ AWS (required when ENV_MODE=aws) ============
#
# Where to get these values:
#
# AWS_REGION / AWS_PROFILE:
#   Run `aws configure` (AWS CLI). Region is e.g. us-east-1.
#   Profile is from ~/.aws/credentials — leave blank to use default profile.
#   Docs: https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-files.html
#
# BEDROCK_MODEL_ID:
#   Go to AWS Console → Amazon Bedrock → Model access → enable "Claude" models.
#   Model IDs listed at: https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html
#   Default: anthropic.claude-sonnet-4-20250514-v1:0 (Claude Sonnet 4)
#
# TITAN_EMBED_MODEL_ID / TITAN_EMBED_DIM:
#   Enable "Titan Text Embeddings V2" in Bedrock console → Model access.
#   V2 supports dimensions 256 / 512 / 1024. Use 1024 for best quality.
#   Docs: https://docs.aws.amazon.com/bedrock/latest/userguide/titan-embedding-models.html
#
# PGVECTOR_URL:
#   PostgreSQL connection string. Requires pgvector extension installed on the DB.
#   For AWS: use Amazon RDS PostgreSQL (15+) with pgvector, or Aurora PostgreSQL.
#   Enable pgvector: CREATE EXTENSION IF NOT EXISTS vector;
#   Format: postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME
#   RDS setup: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/USER_ConnectToPostgreSQLInstance.html
#
# AWS_REGION=us-east-1
# AWS_PROFILE=your-profile
#
# Bedrock LLM (Claude Sonnet 4)
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
#
# Bedrock Titan embeddings V2 (1024-dim — highest quality)
# TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# TITAN_EMBED_DIM=1024
#
# Vector store (cloud default): PGVector on RDS / Aurora PostgreSQL
# PGVECTOR_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME
# PGVECTOR_TABLE=rag_chunks
#
# Optional vector store (alternative): OpenSearch (only if VECTOR_STORE_PROVIDER=opensearch)
# OPENSEARCH_ENDPOINT=https://your-domain-xxxxx.us-east-1.es.amazonaws.com
# OPENSEARCH_INDEX_NAME=pr2po-rag
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=your-password

# ============ Local (required when ENV_MODE=local) ============
# Set at least one LLM: GEMINI_API_KEY and/or GROQ_API_KEY. If both set, Gemini is used.
# QDRANT_URL and QDRANT_API_KEY are always required for local (vector store).

# Option A — Gemini (Google AI). Get key: https://ai.google.dev/gemini-api/docs/api-key
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash

# Option B — Groq
# GROQ_API_KEY=gsk_your_groq_api_key_here
# LOCAL_LLM_MODEL=llama-3.1-8b-instant

# Vector store (required for local)
# QDRANT_URL=https://your-cluster-id.us-east-1-1.aws.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_api_key
# QDRANT_COLLECTION_NAME=pr2po

# ============ Optional (both modes) ============
# DATABASE_URL=sqlite:///pr_validation.db
# LOCAL_DB_PATH=sqlite:///pr_validation.db
